{
  "cSpell.words": ["hayagriva", "Hayagriva", "Tombi"],
  "explorer.fileNesting.patterns": {
    "*.schema.json": "${capture}.yaml,${capture}.yml"
  },
  "json.schemas": [
    {
      "fileMatch": ["docs/*.schema.json"],
      "url": "https://json-schema.org/draft/2020-12/schema"
    }
  ],
  "yaml.schemas": {
    "https://json-schema.org/draft/2020-12/schema": "schemas/*.yaml"
  }
}
